{
  "name": "po-ai-editor",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:po": "pnpm --filter @po-ai-editor/shared build && pnpm --filter @po-ai-editor/server test:po && pnpm --filter @po-ai-editor/web test:po",
    "lint": "turbo lint",
    "format": "prettier --write apps/ packages/",
    "format:check": "prettier --check apps/ packages/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.4",
    "turbo": "^2.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.0.0"
}
