{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["OPENAI_API_KEY", "OPENAI_DEFAULT_MODEL", "OPENAI_ALLOWED_MODELS", "PORT"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["OPENAI_API_KEY", "OPENAI_DEFAULT_MODEL", "OPENAI_ALLOWED_MODELS", "PORT"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "dependsOn": ["^build"]
    }
  }
}
